    <array>
        <string>/Users/shaughnyd/.local/node/bin/node</string>
        <string>--import</string>
        <string>tsx</string>
        <string>/Users/shaughnyd/Documents/GitHub/ORCHESTRA/src/index.ts</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/shaughnyd/Documents/GitHub/ORCHESTRA</string>

    <key>EnvironmentVariables</key>
